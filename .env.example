# DocumentFlow AI — ortam değişkeni örneği (D-011).
# Bu dosyayı proje kökünde `.env` olarak kopyalayıp yerel değerlerinizi girin.
# Gerçek `.env` dosyası Git'e EKLENMEZ. Secret değerleri koda yazılmaz.
#
# Bu tek dosya hem uygulamayı (Pydantic Settings) hem de Docker Compose
# PostgreSQL servisini besler.

APP_ENV=development
LOG_LEVEL=INFO

POSTGRES_DB=documentflow
POSTGRES_USER=documentflow
POSTGRES_PASSWORD=documentflow_local

DATABASE_URL=postgresql+psycopg://documentflow:documentflow_local@localhost:5432/documentflow
